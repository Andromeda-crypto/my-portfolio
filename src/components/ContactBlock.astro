---
import { links } from "../data/siteContent";
---

<div class="contact-panel">
  <div>
    <p class="eyebrow">Contact</p>

    <h2>Let’s connect.</h2>

    <p>
      I’m open to internships, research conversations, technical collaboration,
      and engineering projects where implementation quality matters.
    </p>
  </div>

  <div class="contact-links">
    <a href={links.github} target="_blank" rel="noopener noreferrer">GitHub</a>
    <a href={links.linkedin} target="_blank" rel="noopener noreferrer">LinkedIn</a>
    <a href={links.resume} target="_blank" rel="noopener noreferrer">Resume</a>
    <a href={links.email}>Email</a>
  </div>
</div>