---
import { labItems } from "../data/siteContent";
---

<div class="item-list lab-list">
  {
    labItems.map((item) => (
      <article class="list-item lab-entry">
        <div class="item-meta">
          <span>{item.category}</span>
        </div>

        <div class="item-content">
          <h3>{item.title}</h3>

          <p>{item.description}</p>

          {item.media && item.media.length > 0 && (
            <div class="lab-media-grid">
              {item.media.map((media) => (
                <figure class="lab-media-card">
                  {media.type === "video" ? (
                    <video
                      src={media.src}
                      aria-label={media.alt}
                      controls
                      muted
                      playsinline
                      preload="metadata"
                    />
                  ) : (
                    <img src={media.src} alt={media.alt} loading="lazy" />
                  )}
                </figure>
              ))}
            </div>
          )}

          {item.result && (
            <p class="lab-result">
              <strong>Result:</strong> {item.result}
            </p>
          )}

          <div class="tag-row">
            {item.tags.map((tag) => <span>{tag}</span>)}
          </div>
        </div>
      </article>
    ))
  }
</div>