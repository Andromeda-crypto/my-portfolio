---
import SectionIntro from "../layout/SectionIntro.astro";
---

<section
  class="home-section"
  id="about"
  aria-labelledby="about-heading"
>
  <div class="page-frame home-section__grid">
    <div class="home-section__aside" data-reveal="left">
      <SectionIntro
        index="01"
        eyebrow="About"
        title="A focused engineering portfolio."
        id="about-heading"
      />
    </div>

    <div class="home-section__content">
      <div class="about-section__statement" data-reveal>
        <p>
          I am a Computer Science and Mathematics student at Pennsylvania State
          University, working across robotics, embedded systems, algorithms, and
          technical research.
        </p>
      </div>

      <div class="about-section__grid" data-stagger>
        <article class="about-section__block">
          <h3>What I build</h3>

          <p>
            I work on projects that connect software with real behavior: control
            systems, simulation, numerical methods, hardware integration, and
            algorithmic decision-making.
          </p>
        </article>

        <article class="about-section__block">
          <h3>How I work</h3>

          <p>
            I prefer building from first principles, testing assumptions, and
            documenting the reasoning behind technical decisions rather than
            treating implementation as a black box.
          </p>
        </article>

        <article class="about-section__block">
          <h3>Current direction</h3>

          <p>
            My strongest interests are in robotics engineering, embedded systems,
            controls, probabilistic methods, and research-oriented implementation.
          </p>
        </article>
      </div>
    </div>
  </div>
</section>

<style>
  .about-section__statement {
    max-width: 48rem;
    padding-bottom: clamp(2.5rem, 6vw, 5rem);
  }

  .about-section__statement p {
    color: var(--color-text);
    font-family: var(--font-display);
    font-size: clamp(2rem, 4.8vw, 4.8rem);
    font-weight: var(--font-weight-heavy);
    line-height: 0.98;
    letter-spacing: -0.055em;
  }

  .about-section__grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    border-top: var(--border-thin);
    border-left: var(--border-thin);
  }

  .about-section__block {
    min-height: 18rem;
    padding: clamp(1.4rem, 3vw, 2rem);
    border-right: var(--border-thin);
    border-bottom: var(--border-thin);
  }

  .about-section__block h3 {
    margin-bottom: var(--space-5);
    color: var(--color-accent);
    font-size: var(--text-sm);
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .about-section__block p {
    max-width: 27rem;
    color: var(--color-text-soft);
  }

  @media (max-width: 980px) {
    .about-section__grid {
      grid-template-columns: 1fr 1fr;
    }

    .about-section__block:last-child {
      grid-column: 1 / -1;
      min-height: auto;
    }
  }

  @media (max-width: 640px) {
    .about-section__statement {
      padding-bottom: var(--space-7);
    }

    .about-section__grid {
      grid-template-columns: 1fr;
    }

    .about-section__block,
    .about-section__block:last-child {
      grid-column: auto;
      min-height: auto;
    }
  }
</style>