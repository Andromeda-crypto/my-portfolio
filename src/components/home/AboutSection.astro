---
import { about, profile } from "../../data/siteContent";
---

<section
  class="home-section home-section--compact about-band"
  id="about"
  aria-labelledby="about-heading"
>
  <div class="page-frame about-section">
    <h2 class="about-section__label" id="about-heading">
      About
    </h2>

    <div class="about-section__content" data-reveal>
      <p class="about-section__intro">
        {about.intro}
      </p>

      <p class="about-section__body">
        {about.body}
      </p>

      <p class="about-section__focus">
        {profile.focus}
      </p>
    </div>
  </div>
</section>

<style>
  .about-band {
    position: relative;
    overflow: hidden;
    border-top: var(--border-thin);
    background:
      radial-gradient(
        ellipse 80% 90% at 0% 50%,
        rgba(229, 43, 47, 0.08),
        transparent 55%
      ),
      linear-gradient(
        90deg,
        rgba(24, 26, 27, 0.85),
        transparent 42%
      ),
      var(--color-surface);
  }

  .about-band::before {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    background-image:
      linear-gradient(
        rgba(241, 241, 237, 0.03) 1px,
        transparent 1px
      ),
      linear-gradient(
        90deg,
        rgba(241, 241, 237, 0.03) 1px,
        transparent 1px
      );
    background-size: 48px 48px;
    mask-image: linear-gradient(90deg, rgba(0, 0, 0, 0.55), transparent 70%);
  }

  .about-section {
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 0.4fr) minmax(0, 1.6fr);
    gap: clamp(1.5rem, 5vw, 5rem);
    align-items: start;
    padding-block: clamp(3.5rem, 7vw, 5.5rem);
  }

  .about-section__label {
    color: var(--color-accent);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: var(--font-weight-medium);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
  }

  .about-section__content {
    display: grid;
    gap: var(--space-5);
    max-width: 40rem;
  }

  .about-section__intro {
    color: var(--color-text);
    font-size: clamp(1.1rem, 1.9vw, 1.35rem);
    line-height: 1.5;
  }

  .about-section__body {
    color: var(--color-text-soft);
  }

  .about-section__focus {
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  @media (max-width: 800px) {
    .about-section {
      grid-template-columns: 1fr;
      gap: var(--space-5);
    }

    .about-band::before {
      mask-image: linear-gradient(180deg, rgba(0, 0, 0, 0.4), transparent 75%);
    }
  }
</style>
