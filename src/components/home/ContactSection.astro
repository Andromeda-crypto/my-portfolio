---
import { links } from "../../data/siteContent";
---

<section
  class="home-section home-section--compact"
  id="contact"
  aria-labelledby="contact-heading"
>
  <div class="page-frame">
    <div class="contact-panel">
      <div data-reveal="left">
        <p class="section-kicker">
          Contact
        </p>

        <h2 class="contact-panel__title" id="contact-heading">
          Contact.
        </h2>
      </div>

      <div class="contact-panel__links" data-stagger>
        <a class="button button--primary" href={links.email}>
          Email
        </a>

        <a
          class="button"
          href={links.resume}
          target="_blank"
          rel="noopener noreferrer"
        >
          Résumé
        </a>

        <a
          class="text-link"
          href={links.linkedin}
          target="_blank"
          rel="noopener noreferrer"
        >
          LinkedIn
        </a>

        <a
          class="text-link"
          href={links.github}
          target="_blank"
          rel="noopener noreferrer"
        >
          GitHub
        </a>
      </div>
    </div>
  </div>
</section>
