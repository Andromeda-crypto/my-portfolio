---
import SectionIntro from "../layout/SectionIntro.astro";
import { experience } from "../../data/siteContent";
---

<section
  class="home-section"
  id="experience"
  aria-labelledby="experience-heading"
>
  <div class="page-frame home-section__grid">
    <div class="home-section__aside" data-reveal="left">
      <SectionIntro
        index="01"
        eyebrow="Experience"
        title="Research & internship."
        description="Roles where perception, autonomy, and applied research meet."
        id="experience-heading"
      />
    </div>

    <div class="home-section__content">
      {
        experience.length > 0 ? (
          <div class="experience-list">
            {experience.map((item) => (
              <article class="experience-item" data-reveal>
                <div class="experience-item__meta">
                  <span>{item.period}</span>
                  <span>{item.location}</span>
                </div>

                <div class="experience-item__content">
                  <div>
                    <h3 class="experience-item__role">
                      {item.role}
                    </h3>

                    {item.link ? (
                      <a
                        class="experience-item__company motion-link"
                        href={item.link}
                        target="_blank"
                        rel="noopener noreferrer"
                      >
                        {item.company}
                      </a>
                    ) : (
                      <p class="experience-item__company">
                        {item.company}
                      </p>
                    )}
                  </div>

                  <p class="experience-item__description">
                    {item.description}
                  </p>

                  {item.highlights.length > 0 && (
                    <ul class="experience-item__highlights">
                      {item.highlights.map((highlight) => (
                        <li class="experience-item__highlight">
                          {highlight}
                        </li>
                      ))}
                    </ul>
                  )}
                </div>
              </article>
            ))}
          </div>
        ) : (
          <div class="experience-empty" data-reveal>
            <p class="experience-empty__label">
              Professional experience
            </p>

            <p class="experience-empty__title">
              Details will be added as my professional work develops.
            </p>

            <p class="experience-empty__copy">
              This section is reserved for verified roles, responsibilities,
              and outcomes rather than project work presented as employment.
            </p>
          </div>
        )
      }
    </div>
  </div>
</section>

<style>
  .experience-empty {
    display: grid;
    gap: var(--space-5);
    max-width: 48rem;
    padding:
      clamp(2rem, 5vw, 4rem)
      clamp(1.5rem, 4vw, 3rem);
    border-top: 1px solid var(--color-accent);
    border-bottom: var(--border-thin);
  }

  .experience-empty__label {
    color: var(--color-accent);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
  }

  .experience-empty__title {
    color: var(--color-text);
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 4rem);
    font-weight: var(--font-weight-heavy);
    line-height: 1;
    letter-spacing: var(--tracking-tight);
    text-transform: uppercase;
  }

  .experience-empty__copy {
    max-width: 38rem;
  }
</style>