---
import SectionIntro from "../layout/SectionIntro.astro";
---

<section
  class="home-section home-section--compact"
  id="interests"
  aria-labelledby="interests-heading"
>
  <div class="page-frame">
    <div class="interests-section__header" data-reveal>
      <SectionIntro
        index="06"
        eyebrow="Outside engineering"
        title="Interests."
        description="Football, chess, books, running, swimming, and the activities that occupy the rest of my time."
        id="interests-heading"
      />
    </div>

    <div class="interests-preview" data-stagger>
      <article class="interests-preview__item">
        <h3 class="interests-preview__title">
          Sport
        </h3>

        <p>
          Football has been a central part of my life, alongside
          running, swimming, and badminton.
        </p>
      </article>

      <article class="interests-preview__item">
        <h3 class="interests-preview__title">
          Chess
        </h3>

        <p>
          I enjoy calculation, strategy, patience, and the long-term
          consequences of small decisions.
        </p>
      </article>

      <article class="interests-preview__item">
        <h3 class="interests-preview__title">
          Reading
        </h3>

        <p>
          I read across philosophy, psychology, decision-making,
          fiction, and science fiction.
        </p>
      </article>
    </div>

    <div class="interests-section__action" data-reveal>
      <a class="button" href="/interests/">
        View Interests
      </a>
    </div>
  </div>
</section>

<style>
  .interests-section__header {
    max-width: 58rem;
    margin-bottom: var(--space-8);
  }

  .interests-section__action {
    display: flex;
    justify-content: flex-end;
    margin-top: var(--space-6);
  }

  @media (max-width: 640px) {
    .interests-section__action {
      justify-content: stretch;
    }
  }
</style>