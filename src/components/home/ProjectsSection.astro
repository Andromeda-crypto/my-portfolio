---
import SectionIntro from "../layout/SectionIntro.astro";
import ProjectFeature from "../project/ProjectFeature.astro";
import { projects } from "../../data/siteContent";

const safeProjects = Array.isArray(projects) ? projects : [];
---

<section
  class="home-section"
  id="projects"
  aria-labelledby="projects-heading"
>
  <div class="page-frame">
    <div class="projects-section__intro" data-reveal>
      <SectionIntro
        index="03"
        eyebrow="Projects"
        title="Selected projects."
        description="A selection of systems I have built to understand the problems behind them, not only the finished implementation."
        id="projects-heading"
      />
    </div>

    <div class="project-list">
      {
        safeProjects.map((project, index) => (
          <ProjectFeature
            index={index}
            title={project.title ?? "Untitled Project"}
            type={project.type ?? "Technical Project"}
            description={project.description ?? ""}
            origin={project.origin}
            note={project.note}
            tags={Array.isArray(project.tags) ? project.tags : []}
            links={Array.isArray(project.links) ? project.links : []}
            media={project.media ?? null}
          />
        ))
      }
    </div>
  </div>
</section>

<style>
  .projects-section__intro {
    max-width: 60rem;
    margin-bottom: var(--section-space-md);
  }

  :global(#projects.home-section) {
    padding-bottom: 0;
  }
</style>