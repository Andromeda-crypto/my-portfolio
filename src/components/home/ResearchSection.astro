---
import SectionIntro from "../layout/SectionIntro.astro";
import { research } from "../../data/siteContent";

const safeResearch = Array.isArray(research) ? research : [];
---

<section
  class="home-section research-section"
  id="research"
  aria-labelledby="research-heading"
>
  <div class="page-frame home-section__grid">
    <div class="home-section__aside" data-reveal="left">
      <SectionIntro
        index="05"
        eyebrow="Research"
        title="SLAM implementations."
        description="Paper implementations developed by working through the underlying method and translating it into functioning code."
        id="research-heading"
      />
    </div>

    <div class="home-section__content">
      <div class="research-list">
        {
          safeResearch.map((item, index) => (
            <article class="research-item" data-reveal>
              <span class="research-item__index">
                {String(index + 1).padStart(2, "0")}
              </span>

              <div class="research-item__content">
                <div class="research-item__heading">
                  <h3 class="research-item__title">
                    {item.title}
                  </h3>

                  <span
                    class:list={[
                      "research-item__status",
                      item.status === "In Progress" &&
                        "research-item__status--active"
                    ]}
                  >
                    {item.status}
                  </span>
                </div>

                <p class="research-item__description">
                  {item.description}
                </p>

                {
                  Array.isArray(item.tags) &&
                  item.tags.length > 0 && (
                    <ul
                      class="tag-list"
                      aria-label={`${item.title} topics`}
                    >
                      {
                        item.tags.map((tag) => (
                          <li class="tag">{tag}</li>
                        ))
                      }
                    </ul>
                  )
                }
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </div>
</section>

<style>
  .home-section__aside,
  .home-section__content,
  .research-item__content {
    min-width: 0;
  }

  .research-item__heading {
    display: flex;
    justify-content: space-between;
    gap: var(--space-5);
    align-items: flex-start;
  }

  .research-item__status {
    flex: 0 0 auto;
    display: inline-flex;
    align-items: center;
    min-height: 1.9rem;
    padding-inline: 0.7rem;
    border: 1px solid var(--color-border);
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    font-size: 0.66rem;
    letter-spacing: 0.07em;
    text-transform: uppercase;
  }

  .research-item__status--active {
    border-color: rgba(229, 43, 47, 0.55);
    color: var(--color-accent);
  }

  @media (max-width: 1180px) {
    .home-section__grid {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }

    .home-section__aside {
      position: static;
    }

  }

  @media (max-width: 640px) {
    .research-item__heading {
      align-items: flex-start;
      flex-direction: column;
      gap: var(--space-3);
    }
  }
</style>

<style is:global>
  .research-section .section-heading {
    width: 100%;
    min-width: 0;
    max-width: 100%;
  }

  .research-section .section-heading__title {
    width: 100%;
    max-width: 100%;
    font-size: clamp(2.5rem, 3.1vw, 3.65rem);
    line-height: 0.92;
    letter-spacing: -0.045em;
    text-wrap: balance;
  }

  .research-section .section-heading__copy {
    width: 100%;
    max-width: 36rem;
  }

  @media (max-width: 1180px) {
    .research-section .section-heading__title {
      max-width: 14ch;
      font-size: clamp(3rem, 7vw, 5.2rem);
    }
  }

  @media (max-width: 640px) {
    .research-section .section-heading__title {
      font-size: clamp(2.6rem, 13vw, 4.2rem);
    }
  }
</style>
