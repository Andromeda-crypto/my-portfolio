---
import SectionIntro from "../layout/SectionIntro.astro";
import { stack } from "../../data/siteContent";
---

<section
  class="home-section"
  id="stack"
  aria-labelledby="stack-heading"
>
  <div class="page-frame home-section__grid">
    <div class="home-section__aside" data-reveal="left">
      <SectionIntro
        index="06"
        eyebrow="Stack"
        title="Technical stack."
        description="Languages, robotics tooling, embedded practice, and the workflow I use to ship and debug systems."
        id="stack-heading"
      />
    </div>

    <div class="home-section__content">
      <div class="stack-grid" data-stagger>
        {
          stack.map((group) => (
            <article class="stack-group">
              <h3 class="stack-group__title">{group.title}</h3>

              <ul class="stack-group__list" aria-label={group.title}>
                {group.items.map((item) => (
                  <li class="stack-group__item">{item}</li>
                ))}
              </ul>
            </article>
          ))
        }
      </div>
    </div>
  </div>
</section>

<style>
  .stack-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    border-top: var(--border-thin);
    border-left: var(--border-thin);
  }

  .stack-group {
    display: grid;
    gap: var(--space-5);
    padding: clamp(1.4rem, 3vw, 2rem);
    border-right: var(--border-thin);
    border-bottom: var(--border-thin);
    background: var(--color-surface);
  }

  .stack-group__title {
    color: var(--color-accent);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: var(--font-weight-bold);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .stack-group__list {
    display: grid;
    gap: var(--space-3);
  }

  .stack-group__item {
    position: relative;
    padding-left: 1rem;
    color: var(--color-text-soft);
    font-size: var(--text-base);
  }

  .stack-group__item::before {
    content: "";
    position: absolute;
    top: 0.72em;
    left: 0;
    width: 0.35rem;
    height: 1px;
    background: var(--color-accent);
  }

  @media (max-width: 700px) {
    .stack-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
