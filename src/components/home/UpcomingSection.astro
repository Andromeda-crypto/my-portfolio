---
import SectionIntro from "../layout/SectionIntro.astro";
import { upcoming } from "../../data/siteContent";

const safeUpcoming = Array.isArray(upcoming) ? upcoming : [];
---

<section
  class="home-section"
  id="upcoming"
  aria-labelledby="upcoming-heading"
>
  <div class="page-frame home-section__grid">
    <div class="home-section__aside" data-reveal="left">
      <SectionIntro
        index="03"
        eyebrow="Upcoming"
        title="What's next."
        description="Controls and autonomy projects queued after current research and hardware work."
        id="upcoming-heading"
      />
    </div>

    <div class="home-section__content">
      <div class="upcoming-list">
        {
          safeUpcoming.map((item, index) => (
            <article class="upcoming-item" data-reveal>
              <span class="upcoming-item__index">
                {String(index + 1).padStart(2, "0")}
              </span>

              <div class="upcoming-item__content">
                <div class="upcoming-item__heading">
                  <h3 class="upcoming-item__title">
                    {item.title}
                  </h3>

                  <span
                    class:list={[
                      "upcoming-item__status",
                      item.status === "Next" &&
                        "upcoming-item__status--next",
                      item.status === "Deferred" &&
                        "upcoming-item__status--deferred"
                    ]}
                  >
                    {item.status}
                  </span>
                </div>

                <p class="upcoming-item__description">
                  {item.description}
                </p>

                {
                  Array.isArray(item.tags) && item.tags.length > 0 && (
                    <ul
                      class="tag-list"
                      aria-label={`${item.title} topics`}
                    >
                      {item.tags.map((tag) => (
                        <li class="tag">{tag}</li>
                      ))}
                    </ul>
                  )
                }
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </div>
</section>

<style>
  .upcoming-item__heading {
    display: flex;
    justify-content: space-between;
    gap: var(--space-5);
    align-items: flex-start;
  }

  .upcoming-item__status {
    flex: 0 0 auto;
    display: inline-flex;
    align-items: center;
    min-height: 1.9rem;
    padding-inline: 0.7rem;
    border: 1px dashed rgba(229, 43, 47, 0.45);
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    font-size: 0.66rem;
    letter-spacing: 0.07em;
    text-transform: uppercase;
  }

  .upcoming-item__status--next {
    border-style: solid;
    border-color: rgba(229, 43, 47, 0.55);
    color: var(--color-accent);
  }

  .upcoming-item__status--deferred {
    border-color: var(--color-border);
    border-style: dashed;
    color: var(--color-text-muted);
  }

  @media (max-width: 640px) {
    .upcoming-item__heading {
      align-items: flex-start;
      flex-direction: column;
      gap: var(--space-3);
    }
  }
</style>
