---
import { links } from "../../data/siteContent";

const year = new Date().getFullYear();

const footerLinks = [
  {
    label: "GitHub",
    href: links.github
  },
  {
    label: "LinkedIn",
    href: links.linkedin
  },
  {
    label: "Résumé",
    href: links.resume
  },
  {
    label: "Email",
    href: links.email
  }
];
---

<footer class="site-footer site-footer--minimal">
  <div class="page-frame">
    <div class="site-footer-minimal__top">
      <p class="section-marker">
        Contact
      </p>

      <nav
        class="site-footer-minimal__links"
        aria-label="Footer links"
      >
        {
          footerLinks.map((link) => (
            <a
              class="site-footer__link"
              href={link.href}
              target={link.href.startsWith("mailto:") ? undefined : "_blank"}
              rel={
                link.href.startsWith("mailto:")
                  ? undefined
                  : "noopener noreferrer"
              }
            >
              {link.label}
            </a>
          ))
        }
      </nav>
    </div>

    <div class="site-footer__bottom">
      <span>© {year} Om Anand</span>
      <span>Computer Science &amp; Mathematics</span>
    </div>
  </div>
</footer>

<style>
  .site-footer--minimal {
    padding-block: var(--space-8) var(--space-6);
  }

  .site-footer-minimal__top {
    display: flex;
    justify-content: space-between;
    gap: var(--space-7);
    align-items: center;
  }

  .site-footer-minimal__links {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: var(--space-5);
  }

  @media (max-width: 700px) {
    .site-footer-minimal__top {
      align-items: flex-start;
      flex-direction: column;
    }

    .site-footer-minimal__links {
      justify-content: flex-start;
    }
  }
</style>