---
import BaseLayout from "../layouts/BaseLayout.astro";

import KineticHero from "../components/home/KineticHero.astro";
import AboutSection from "../components/home/AboutSection.astro";
import ExperienceSection from "../components/home/ExperienceSection.astro";
import ProjectsSection from "../components/home/ProjectsSection.astro";
import LabPreview from "../components/home/LabPreview.astro";
import ResearchSection from "../components/home/ResearchSection.astro";
import InterestsPreview from "../components/home/InterestsPreview.astro";
import ContactSection from "../components/home/ContactSection.astro";
---

<BaseLayout
  title="Om Anand | Engineering Portfolio"
  description="Portfolio of Om Anand, a Computer Science and Mathematics student working across robotics, embedded systems, algorithms, and technical research."
  bodyClass="home-page"
>
  <KineticHero />

  <AboutSection />

  <ExperienceSection />

  <ProjectsSection />

  <LabPreview />

  <ResearchSection />

  <InterestsPreview />

  <ContactSection />
</BaseLayout>

<script>
  import { initializeScrollAnimations } from "../components/motion/scrollAnimations";

  const initializePage = () => {
    document.body.classList.add("is-ready");
    initializeScrollAnimations();
  };

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initializePage, {
      once: true
    });
  } else {
    initializePage();
  }
</script>