---
import BaseLayout from "../layouts/BaseLayout.astro";

import KineticHero from "../components/home/KineticHero.astro";
import CapabilityStrip from "../components/home/CapabilityStrip.astro";
import AboutSection from "../components/home/AboutSection.astro";
import FeaturedWork from "../components/home/FeaturedWork.astro";
import ExperienceSection from "../components/home/ExperienceSection.astro";
import UpcomingSection from "../components/home/UpcomingSection.astro";
import LabPreview from "../components/home/LabPreview.astro";
import ResearchSection from "../components/home/ResearchSection.astro";
import StackSection from "../components/home/StackSection.astro";
import ContactSection from "../components/home/ContactSection.astro";
---

<BaseLayout
  title="Om Anand | Robotics & Controls"
  description="Portfolio of Om Anand — robotics, embedded systems, and closed-loop control. CS & Mathematics student seeking internships in robotics and controls."
  bodyClass="home-page"
>
  <KineticHero />

  <CapabilityStrip />

  <AboutSection />

  <ExperienceSection />

  <FeaturedWork />

  <UpcomingSection />

  <LabPreview />

  <ResearchSection />

  <StackSection />

  <ContactSection />
</BaseLayout>

<script>
  import { initializeScrollAnimations } from "../components/motion/scrollAnimations";

  const initializePage = () => {
    document.body.classList.add("is-ready");
    initializeScrollAnimations();
  };

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initializePage, {
      once: true
    });
  } else {
    initializePage();
  }
</script>
