---
import BaseLayout from "../layouts/BaseLayout.astro";
import { interests, links } from "../data/siteContent";
---

<BaseLayout
  title="Om Anand | Interests"
  description="Books, sport, chess, and interests outside engineering."
  bodyClass="interests-page"
>
  <section class="subpage-hero">
    <div class="page-frame subpage-hero__inner">
      <p class="section-kicker">Outside engineering</p>

      <h1>Interests.</h1>

      <p>
        Sport, chess, books, and the activities that occupy the rest
        of my time.
      </p>
    </div>
  </section>

  <section class="home-section">
    <div class="page-frame interests-section">
      <div class="interests-section__header">
        <p class="section-kicker">Reading</p>
        <h2>Books.</h2>
      </div>

      <div class="reading-grid">
        <article class="content-card reading-card">
          <p class="mono-label">Currently reading</p>

          <ul>
            {
              interests.reading.current.map((book) => (
                <li>{book}</li>
              ))
            }
          </ul>
        </article>

        <article class="content-card reading-card">
          <p class="mono-label">Selected favourites</p>

          <ul>
            {
              interests.reading.favorites.map((book) => (
                <li>{book}</li>
              ))
            }
          </ul>
        </article>
      </div>
    </div>
  </section>

  <section class="home-section">
    <div class="page-frame interests-section">
      <div class="interests-section__header">
        <p class="section-kicker">Sports & games</p>
        <h2>What I play.</h2>
      </div>

      <div class="sports-grid">
        {
          interests.sports.map((sport) => (
            <article class="sports-card">
              <h3>{sport.title}</h3>

              <p>{sport.description}</p>

              {sport.title === "Chess" && (
                <a
                  class="text-link"
                  href={links.chessCom}
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  Chess.com profile
                </a>
              )}
            </article>
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  import { initializeScrollAnimations } from "../components/motion/scrollAnimations";

  const initializePage = () => {
    document.body.classList.add("is-ready");
    initializeScrollAnimations();
  };

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initializePage, {
      once: true
    });
  } else {
    initializePage();
  }
</script>

<style>
  .subpage-hero {
    display: flex;
    align-items: end;
    min-height: 78svh;
    padding-top: 7rem;
    border-bottom: var(--border-thin);
  }

  .subpage-hero__inner {
    padding-bottom: var(--section-space-lg);
  }

  .subpage-hero h1 {
    margin-top: var(--space-4);
    font-size: clamp(5rem, 15vw, 13rem);
    line-height: 0.82;
    letter-spacing: var(--tracking-display);
    text-transform: uppercase;
  }

  .subpage-hero p:last-child {
    max-width: 42rem;
    margin-top: var(--space-6);
    font-size: var(--text-lg);
  }

  .interests-section__header {
    margin-bottom: var(--space-8);
  }

  .interests-section__header h2 {
    margin-top: var(--space-3);
    font-size: var(--text-3xl);
    text-transform: uppercase;
  }

  .reading-grid {
    display: grid;
    grid-template-columns: 0.75fr 1.25fr;
    border-top: var(--border-thin);
    border-left: var(--border-thin);
  }

  .reading-card {
    display: grid;
    align-content: start;
    gap: var(--space-6);
    min-height: 20rem;
    border-top: 0;
    border-left: 0;
  }

  .reading-card ul {
    display: grid;
    gap: var(--space-4);
  }

  .reading-card li {
    color: var(--color-text);
    font-family: var(--font-display);
    font-size: clamp(1.4rem, 2.5vw, 2.3rem);
    font-weight: var(--font-weight-heavy);
    line-height: 1.05;
    letter-spacing: var(--tracking-tight);
  }

  .sports-grid {
    display: grid;
    border-top: var(--border-thin);
  }

  .sports-card {
    display: grid;
    grid-template-columns: minmax(10rem, 0.45fr) minmax(0, 1fr) auto;
    gap: clamp(1.5rem, 5vw, 5rem);
    align-items: start;
    padding-block: clamp(2rem, 5vw, 3.5rem);
    border-bottom: var(--border-thin);
  }

  .sports-card h3 {
    font-size: var(--text-2xl);
    text-transform: uppercase;
  }

  .sports-card p {
    max-width: 42rem;
  }

  @media (max-width: 800px) {
    .reading-grid {
      grid-template-columns: 1fr;
    }

    .sports-card {
      grid-template-columns: 1fr;
    }
  }
</style>