---
import BaseLayout from "../layouts/BaseLayout.astro";
import { cadStudies, labItems } from "../data/siteContent";
---

<BaseLayout
  title="Om Anand | Engineering Lab"
  description="Hardware experiments, IMU telemetry, control-feedback prototypes, and early CAD studies by Om Anand."
  bodyClass="lab-page"
>
  <section class="subpage-hero">
    <div class="page-frame subpage-hero__inner">
      <p class="section-kicker">Engineering Lab</p>

      <h1>Hardware &amp; experiments.</h1>

      <p>
        Completed prototypes, IMU telemetry, control-feedback visualization,
        and early mechanical-design studies for robotics work.
      </p>
    </div>
  </section>

  <section class="home-section">
    <div class="page-frame">
      {
        labItems.map((item) => (
          <article class="lab-entry">
            <div class="lab-entry__header">
              <div>
                <p class="section-kicker">{item.category}</p>
                <h2>{item.title}</h2>
              </div>

              <p>{item.description}</p>
            </div>

            <div class="lab-entry__media">
              {item.media.map((media, index) => (
                <figure
                  class:list={[
                    "media-frame",
                    "media-reveal",
                    "lab-entry__media-item",
                    index === 0 && "lab-entry__media-item--primary"
                  ]}
                >
                  {media.type === "video" ? (
                    <video
                      src={media.src}
                      aria-label={media.alt}
                      controls
                      muted
                      playsinline
                      preload="metadata"
                    />
                  ) : (
                    <img
                      src={media.src}
                      alt={media.alt}
                      loading="lazy"
                    />
                  )}
                </figure>
              ))}
            </div>

            <div class="lab-entry__result">
              <p class="section-kicker">Result</p>
              <p>{item.result}</p>

              <ul class="tag-list">
                {item.tags.map((tag) => (
                  <li class="tag">{tag}</li>
                ))}
              </ul>
            </div>
          </article>
        ))
      }
    </div>
  </section>

  <section class="home-section" id="cad">
    <div class="page-frame">
      <div class="cad-header">
        <div>
          <p class="section-kicker">CAD &amp; mechanical design</p>
          <h2>Early CAD studies.</h2>
        </div>

        <p>
          Foundational CAD skills through tutorial-led part models. This
          section expands into mounts, assemblies, and robotics-oriented
          mechanical designs as the practice deepens. Drop renders into
          <code>public/media/cad/</code> when ready.
        </p>
      </div>

      <div class="cad-grid">
        {
          cadStudies.map((item) => (
            <article class="cad-study">
              <div
                class="cad-study__media media-frame"
                role="img"
                aria-label={`${item.title} modelling pipeline`}
              >
                <div class="cad-study__diagram">
                  <span class="cad-study__diagram-kicker">
                    Modelling pipeline
                  </span>

                  <ol class="cad-study__pipeline">
                    {item.pipeline.map((stage, stageIndex) => (
                      <li>
                        <span>
                          {String(stageIndex + 1).padStart(2, "0")}
                        </span>
                        <span>{stage}</span>
                      </li>
                    ))}
                  </ol>

                  <p class="cad-study__caption">Render forthcoming</p>
                </div>
              </div>

              <div class="cad-study__body">
                <p class="mono-label">{item.stage}</p>
                <h3>{item.title}</h3>
                <p>{item.description}</p>

                <ul class="tag-list">
                  {item.tags.map((tag) => (
                    <li class="tag">{tag}</li>
                  ))}
                </ul>
              </div>
            </article>
          ))
        }

        <article class="cad-study cad-study--future">
          <div class="cad-study__body">
            <p class="mono-label">Future additions</p>
            <h3>Design work in progress.</h3>
            <p>
              Future entries will include original parts, design iterations,
              exported renders, assemblies, and mechanical work connected to
              physical robotics projects.
            </p>
          </div>
        </article>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  import { initializeScrollAnimations } from "../components/motion/scrollAnimations";

  const initializePage = () => {
    document.body.classList.add("is-ready");
    initializeScrollAnimations();
  };

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initializePage, {
      once: true
    });
  } else {
    initializePage();
  }
</script>

<style>
  .subpage-hero {
    display: flex;
    align-items: end;
    min-height: 78svh;
    padding-top: 7rem;
    border-bottom: var(--border-thin);
  }

  .subpage-hero__inner {
    padding-bottom: var(--section-space-lg);
  }

  .subpage-hero h1 {
    max-width: 12ch;
    margin-top: var(--space-4);
    font-size: clamp(4rem, 11vw, 10rem);
    line-height: 0.86;
    letter-spacing: var(--tracking-display);
    text-transform: uppercase;
  }

  .subpage-hero p:last-child {
    max-width: 44rem;
    margin-top: var(--space-6);
    font-size: var(--text-lg);
  }

  .lab-entry {
    padding-block: var(--section-space-lg);
    border-bottom: var(--border-thin);
  }

  .lab-entry:first-child {
    padding-top: 0;
  }

  .lab-entry__header {
    display: grid;
    grid-template-columns: minmax(0, 0.8fr) minmax(0, 1.2fr);
    gap: clamp(2rem, 7vw, 7rem);
    margin-bottom: var(--space-8);
  }

  .lab-entry__header h2,
  .cad-header h2 {
    margin-top: var(--space-3);
    font-size: var(--text-3xl);
    text-transform: uppercase;
  }

  .lab-entry__media {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-4);
  }

  .lab-entry__media-item {
    aspect-ratio: 4 / 3;
  }

  .lab-entry__media-item--primary {
    grid-column: 1 / -1;
    aspect-ratio: 16 / 9;
  }

  .lab-entry__result {
    display: grid;
    gap: var(--space-5);
    max-width: 52rem;
    margin-top: var(--space-7);
    padding-left: var(--space-5);
    border-left: 2px solid var(--color-accent);
  }

  .cad-header {
    display: grid;
    grid-template-columns: minmax(0, 0.8fr) minmax(0, 1.2fr);
    gap: clamp(2rem, 7vw, 7rem);
    margin-bottom: var(--space-8);
  }

  .cad-header code {
    color: var(--color-accent);
    font-family: var(--font-mono);
    font-size: 0.85em;
  }

  .cad-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--space-5);
  }

  .cad-study {
    display: grid;
    grid-template-rows: auto 1fr;
    border: var(--border-thin);
    background: var(--color-surface);
  }

  .cad-study__media {
    aspect-ratio: 4 / 3;
    border: 0;
    border-bottom: var(--border-thin);
  }

  .cad-study__diagram {
    display: grid;
    grid-template-rows: auto 1fr auto;
    gap: var(--space-4);
    height: 100%;
    padding: var(--space-5);
    background:
      linear-gradient(
        135deg,
        rgba(229, 43, 47, 0.1),
        transparent 42%
      ),
      var(--color-surface);
  }

  .cad-study__diagram-kicker {
    color: var(--color-accent);
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .cad-study__pipeline {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-2);
    align-content: center;
  }

  .cad-study__pipeline li {
    display: grid;
    gap: var(--space-1);
    padding: var(--space-3);
    border: 1px solid var(--color-border);
    background: rgba(9, 10, 10, 0.5);
  }

  .cad-study__pipeline li span:first-child {
    color: var(--color-accent);
    font-family: var(--font-mono);
    font-size: 0.58rem;
    letter-spacing: 0.08em;
  }

  .cad-study__pipeline li span:last-child {
    color: var(--color-text);
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .cad-study__caption {
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    font-size: 0.58rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .cad-study__body {
    display: grid;
    align-content: start;
    gap: var(--space-4);
    padding: clamp(1.2rem, 2.5vw, 1.6rem);
  }

  .cad-study__body h3 {
    font-size: clamp(1.4rem, 2.2vw, 1.9rem);
    text-transform: uppercase;
  }

  .cad-study--future {
    background:
      linear-gradient(
        135deg,
        var(--color-red-soft),
        transparent 60%
      ),
      var(--color-surface);
  }

  .cad-study--future .cad-study__body {
    min-height: 100%;
    padding: clamp(1.6rem, 3vw, 2.2rem);
  }

  @media (max-width: 900px) {
    .lab-entry__header,
    .cad-header {
      grid-template-columns: 1fr;
    }

    .cad-grid {
      grid-template-columns: 1fr 1fr;
    }

    .cad-study--future {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 640px) {
    .lab-entry__media,
    .cad-grid {
      grid-template-columns: 1fr;
    }

    .lab-entry__media-item--primary,
    .cad-study--future {
      grid-column: auto;
    }

    .lab-entry__media-item,
    .lab-entry__media-item--primary {
      aspect-ratio: 4 / 3;
    }
  }
</style>
